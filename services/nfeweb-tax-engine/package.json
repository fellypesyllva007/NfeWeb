{
  "name": "@nfeweb/tax-engine",
  "version": "0.1.0",
  "private": true,
  "description": "NfeWeb Tax Engine API for parametrized Brazilian NF-e tax calculation previews and official snapshots.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@supabase/supabase-js": "^2.45.4",
    "decimal.js": "^10.4.3",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "pino": "^9.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "eslint": "^9.9.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
