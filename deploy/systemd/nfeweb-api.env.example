# Ambiente da API NfeWeb / fiscal-service
# Copiar para:
#   /etc/nfeweb/nfeweb-api.env
#
# Ajustar permissões:
#   sudo chown root:root /etc/nfeweb/nfeweb-api.env
#   sudo chmod 600 /etc/nfeweb/nfeweb-api.env

NODE_ENV=production
HOST=127.0.0.1
PORT=3333

# ACBr ARM64
ACBR_HOME=/home/ubuntu/acbr-arm64-lab/ACBr
ACBR_NFE_LIB=/home/ubuntu/acbr-arm64-lab/ACBr/Projetos/ACBrLib/Fontes/NFe/bin/Linux/CONSOLE-MT/libacbrnfe_arm64.so

# OpenSSL 3 providers. Precisam existir antes do processo carregar a libacbrnfe_arm64.so.
OPENSSL_CONF=/etc/nfeweb/openssl-acbr.cnf
OPENSSL_MODULES=/usr/lib/aarch64-linux-gnu/ossl-modules

# Certificado A1. Em produção, usar certificado ICP-Brasil real e senha protegida.
NFE_PFX_PATH=/etc/nfeweb/certs/certificado-a1.pfx
NFE_PFX_PASSWORD=trocar-esta-senha

# NF-e
NFE_UF=SP
NFE_AMBIENTE=1
NFE_PATH_SCHEMAS=/home/ubuntu/acbr-arm64-lab/ACBr/Exemplos/ACBrDFe/Schemas/NFe
NFE_PATH_SALVAR=/var/lib/nfeweb/notas
NFE_LOG_PATH=/var/log/nfeweb
